# Address of the hashit-idx gRPC Search daemon (read-only, runs on :50551)
HASHIT_SEARCH_ADDR=127.0.0.1:50551

# Address of the hashit gRPC FileOps server (mutations, runs on :50552)
# Requires: hashit watch --serve [--meta-folder PATH]
HASHIT_FILEOPS_ADDR=127.0.0.1:50552

# API key that gates the web UI and public API routes.
# External clients send: Authorization: Bearer <key>
# Web UI stores this in a session cookie after logging in.
# Leave blank to disable auth (private network / dev only).
PUBLIC_API_KEY=change-me-to-a-random-secret
