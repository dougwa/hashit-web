# URL of your running hashit API (default: http://127.0.0.1:8087)
HASHIT_URL=http://127.0.0.1:8087

# Bearer token if hashit was started with --token <t> (leave blank for --no-token)
HASHIT_TOKEN=

# API key that gates the public /api/v1/* proxy routes and the web UI.
# External clients (mobile apps, integrations) send: Authorization: Bearer <key>
# Web UI stores this in a session cookie after logging in.
# Leave blank to disable auth entirely (only do this on a private network).
PUBLIC_API_KEY=change-me-to-a-random-secret
